{
  "name": "@ddhd/feishu-skills",
  "version": "2.0.0",
  "description": "飞书开放平台自进化 SKILL，提供通讯录、考勤、云空间等基础能力，支持业务场景快速组合",
  "main": "lib/index.ts",
  "types": "lib/index.ts",
  "bin": {
    "feishu-today-attendance": "scripts/today-attendance.ts",
    "feishu-media-manager": "scripts/media-manager.ts",
    "feishu-contact-query": "scripts/contact-query.ts"
  },
  "exports": {
    ".": {
      "import": "./lib/index.ts",
      "require": "./lib/index.ts"
    },
    "./lib/*": {
      "import": "./lib/*.ts",
      "require": "./lib/*.ts"
    },
    "./scripts/*": {
      "import": "./scripts/*.ts",
      "require": "./scripts/*.ts"
    }
  },
  "keywords": [
    "feishu",
    "lark",
    "sdk",
    "skill",
    "attendance",
    "contact",
    "media",
    "飞书",
    "自进化"
  ],
  "author": "DDHD",
  "license": "ISC",
  "engines": {
    "node": ">=16.0.0"
  },
  "packageManager": "pnpm@10.26.0",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1"
  }
}
